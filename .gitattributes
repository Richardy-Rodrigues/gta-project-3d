# ============================================================
# Git LFS configuration for Unity
# Tracks large binary assets so they don't bloat the Git history.
# Requires: git lfs install (run once per machine)
# ============================================================

# Normalize line endings: let Git handle text automatically.
* text=auto

# Unity text assets that must stay as text and diffable (forced LF).
*.cs                 text eol=lf diff=csharp
*.shader             text
*.cginc              text
*.hlsl               text
*.compute            text
*.json               text
*.txt                text
*.md                 text
*.uss                text
*.uxml               text

# Unity YAML assets — keep as text so the Smart Merge (UnityYAMLMerge) tool works.
*.unity              merge=unityyamlmerge eol=lf
*.meta               merge=unityyamlmerge eol=lf
*.asset              merge=unityyamlmerge eol=lf
*.prefab             merge=unityyamlmerge eol=lf
*.mat                merge=unityyamlmerge eol=lf
*.anim               merge=unityyamlmerge eol=lf
*.controller         merge=unityyamlmerge eol=lf
*.overrideController merge=unityyamlmerge eol=lf
*.physicMaterial     merge=unityyamlmerge eol=lf
*.physicsMaterial2D  merge=unityyamlmerge eol=lf
*.playable           merge=unityyamlmerge eol=lf
*.mask               merge=unityyamlmerge eol=lf
*.brush              merge=unityyamlmerge eol=lf
*.flare              merge=unityyamlmerge eol=lf
*.fontsettings       merge=unityyamlmerge eol=lf
*.guiskin            merge=unityyamlmerge eol=lf
*.giparams           merge=unityyamlmerge eol=lf
*.renderTexture      merge=unityyamlmerge eol=lf
*.spriteatlas        merge=unityyamlmerge eol=lf
*.terrainlayer       merge=unityyamlmerge eol=lf
*.mixer              merge=unityyamlmerge eol=lf
*.preset             merge=unityyamlmerge eol=lf
*.signal             merge=unityyamlmerge eol=lf

# ============================================================
# Git LFS — binary assets
# ============================================================

# 3D models
*.fbx    filter=lfs diff=lfs merge=lfs -text
*.FBX    filter=lfs diff=lfs merge=lfs -text
